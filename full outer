WITH CompareData AS
(
SELECT
    COALESCE(wfm.ba_account_number, sc.BAAccountNumber) AS ba_account,
    COALESCE(wfm.calldatetime, sc.CallDateTime) AS date,

    wfm.hold_time  AS wfm_hold_time,
    sc.HoldTime    AS sc_hold_time,

    wfm.csl_name   AS wfm_csl_name,
    sc.CSL_Name    AS sc_csl_name,

    wfm.disposition_name AS wfm_disposition,
    sc.DispositionName   AS sc_disposition,

    wfm.ob_file_name AS wfm_file,
    sc.FileName      AS sc_file,

    wfm.phone AS wfm_phone,
    sc.phone  AS sc_phone,

    -- difference flags
    CASE WHEN ISNULL(wfm.hold_time,-1) <> ISNULL(sc.HoldTime,-1)
         THEN 1 ELSE 0 END AS hold_time_diff,

    CASE WHEN TRIM(LOWER(ISNULL(wfm.csl_name,''))) <>
              TRIM(LOWER(ISNULL(sc.CSL_Name,'')))
         THEN 1 ELSE 0 END AS csl_name_diff,

    CASE WHEN TRIM(LOWER(ISNULL(wfm.disposition_name,''))) <>
              TRIM(LOWER(ISNULL(sc.DispositionName,'')))
         THEN 1 ELSE 0 END AS disposition_diff,

    CASE WHEN TRIM(LOWER(ISNULL(wfm.ob_file_name,''))) <>
              TRIM(LOWER(ISNULL(sc.FileName,'')))
         THEN 1 ELSE 0 END AS file_diff,

    CASE WHEN ISNULL(wfm.phone,'') <> ISNULL(sc.phone,'')
         THEN 1 ELSE 0 END AS phone_diff

FROM fact_outbound_dialer_202601 wfm
FULL OUTER JOIN outbound_src_tdct sc
    ON sc.BAAccountNumber = wfm.ba_account_number
   AND sc.CallDateTime   = wfm.calldatetime
)

SELECT *
FROM CompareData
WHERE
       hold_time_diff = 1
    OR csl_name_diff = 1
    OR disposition_diff = 1
    OR file_diff = 1
    OR phone_diff = 1
    OR wfm_hold_time IS NULL
    OR sc_hold_time IS NULL
ORDER BY date, ba_account;