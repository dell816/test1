%sql

WITH CompareData AS (
SELECT
    COALESCE(wfm.ba_account_number, sc.BAAccountNumber) AS ba_account,
    COALESCE(wfm.calldatetime, sc.CallDateTime) AS date,

    wfm.hold_time  AS ath_hold_time,
    sc.HoldTime    AS sc_hold_time,

    TRIM(LOWER(wfm.csl_name)) AS ath_csl_name,
    TRIM(LOWER(sc.CSL_Name))  AS sc_csl_name,

    TRIM(LOWER(wfm.disposition_name)) AS ath_disposition,
    TRIM(LOWER(sc.DispositionName))   AS sc_disposition,

    TRIM(LOWER(wfm.ob_file_name)) AS ath_file_name,
    TRIM(LOWER(sc.FileName))      AS sc_file_name,

    wfm.phone AS ath_phone,
    sc.phone  AS sc_phone,

    CASE 
        WHEN COALESCE(wfm.hold_time,-1) <> COALESCE(sc.HoldTime,-1)
        THEN 1 ELSE 0
    END AS hold_time_diff,

    CASE 
        WHEN TRIM(LOWER(COALESCE(wfm.csl_name,''))) <>
             TRIM(LOWER(COALESCE(sc.CSL_Name,'')))
        THEN 1 ELSE 0
    END AS csl_name_diff,

    CASE 
        WHEN TRIM(LOWER(COALESCE(wfm.disposition_name,''))) <>
             TRIM(LOWER(COALESCE(sc.DispositionName,'')))
        THEN 1 ELSE 0
    END AS disposition_diff,

    CASE 
        WHEN TRIM(LOWER(COALESCE(wfm.ob_file_name,''))) <>
             TRIM(LOWER(COALESCE(sc.FileName,'')))
        THEN 1 ELSE 0
    END AS file_name_diff,

    CASE 
        WHEN COALESCE(wfm.phone,'') <> COALESCE(sc.phone,'')
        THEN 1 ELSE 0
    END AS phone_diff

FROM fact_outbound_dialer_202601 wfm
FULL OUTER JOIN outbound_src_tdct sc
    ON sc.BAAccountNumber = wfm.ba_account_number
   AND sc.CallDateTime = wfm.calldatetime
)

SELECT *
FROM CompareData
WHERE
      hold_time_diff = 1
   OR csl_name_diff = 1
   OR disposition_diff = 1
   OR file_name_diff = 1
   OR phone_diff = 1
   OR ath_hold_time IS NULL
   OR sc_hold_time IS NULL
ORDER BY date, ba_account;